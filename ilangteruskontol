.edge-right{right:0;background:linear-gradient(180deg,#ff0000,#D4780A 20%,#8B4500 40%,#3d1c00 60%,#8B4500 80%,#D4780A 90%,#ff0000);}
.edge-left::after,.edge-right::after{content:'';position:absolute;inset:0;background:inherit;filter:blur(6px);opacity:0.6;animation:edgePulse 3s ease-in-out infinite alternate;}
.lamps{position:absolute;top:8px;bottom:0;width:100%;pointer-events:none;z-index:11;}
.lamp{position:absolute;width:12px;height:12px;border-radius:50%;background:radial-gradient(circle,#fffde0 0%,#ffd00040%,#D4780A 80%);box-shadow:0 0 8px 4px rgba(255,215,0,0.6),0 0 18px 8px rgba(180,100,0,0.35);animation:lampBlink 2s ease-in-out infinite alternate;}
